# .clangd

CompileFlags:
  Add:
    # ========== 编译用头文件 ==========
    - -IC:/Qt/6.6.2/msvc2019_64/include
    - -IC:/Qt/6.6.2/msvc2019_64/include/QtCore
    - -IC:/Qt/6.6.2/msvc2019_64/include/QtGui
    - -IC:/Qt/6.6.2/msvc2019_64/include/QtWidgets
    - -IC:/Qt/6.6.2/msvc2019_64/include/QtSvg
    
    # ========== ⭐ 关键：直接告诉 clangd Qt 源码路径（用于跳转到 .cpp） ==========
    - -I"C:/Qt/6.6.2/Src/qtbase/src"
    - -I"C:/Qt/6.6.2/Src/qtbase/src/corelib"
    - -I"C:/Qt/6.6.2/Src/qtbase/src/gui"
    - -I"C:/Qt/6.6.2/Src/qtbase/src/widgets"
    - -I"C:/Qt/6.6.2/Src/qtbase/src/plugins/platforms/windows"
    - -I"C:/Qt/6.6.2/Src/qtbase/include"
    - -I"C:/Qt/6.6.2/Src/qtbase/include/QtCore"
    - -I"C:/Qt/6.6.2/Src/qtbase/include/QtGui"
    - -I"C:/Qt/6.6.2/Src/qtbase/include/QtWidgets"
    - -I"C:/Qt/6.6.2/Src/qtsvg/src/svg"
    - -I"C:/Qt/6.6.2/Src/qtdeclarative/src/quick"
    
    # ========== Qt 宏定义 ==========
    - -DQT_CORE_LIB
    - -DQT_GUI_LIB
    - -DQT_WIDGETS_LIB
    - -DQT_SVG_LIB
    - -DQT_VERSION=0x060602
    - -DQT_VERSION_MAJOR=6
    - -DQT_VERSION_MINOR=6
    
    # ========== MSVC 兼容 ==========
    - -D_CRT_SECURE_NO_WARNINGS
    - -D_SCL_SECURE_NO_WARNINGS
    - -DUNICODE
    - -D_UNICODE
    - -D_WIN32
    - -DWIN32
    - -D_WINDOWS
    - -D_MBCS

  Remove:
    - -march=*
    - -Werror

Index:
  Background: true
  # 让 clangd 索引这些目录

InlayHints:
  Enabled: true
  ParameterNames: true
  DeducedTypes: true